{
  "schema_version": "1",
  "tasks": [
    {
      "task_id": "direct_csv_load",
      "track": "direct_reuse",
      "prompt": "Load the supplied comma-separated transaction file as a table.",
      "input_artifact_type": "file/csv",
      "required_output_type": "table/pandas-dataframe",
      "required_stages": ["load"],
      "input_path": "data/seed/transactions.csv",
      "expected_columns": ["category", "amount"],
      "expected_row_count": 5,
      "route": [
        {"capability_id": "pandas.read_csv", "bindings": {}}
      ]
    },
    {
      "task_id": "grouped_json_report",
      "track": "multi_capability_composition",
      "prompt": "Read the transaction CSV, replace missing amounts with zero, sum amount by category, and write JSON records.",
      "input_artifact_type": "file/csv",
      "required_output_type": "file/json-records",
      "required_stages": ["load", "missing-values", "group", "aggregate", "adapt", "write"],
      "input_path": "data/seed/transactions.csv",
      "expected_rows": [
        {"category": "A", "amount": 10.0},
        {"category": "B", "amount": 12.0},
        {"category": "C", "amount": 2.0}
      ],
      "route": [
        {"capability_id": "pandas.read_csv", "bindings": {}},
        {"capability_id": "pandas.DataFrame.fillna", "bindings": {"value": {"amount": 0}}},
        {"capability_id": "pandas.DataFrame.groupby", "bindings": {"by": "category"}},
        {"capability_id": "pandas.core.groupby.DataFrameGroupBy.sum", "bindings": {"column": "amount"}},
        {"capability_id": "pandas.Series.reset_index", "bindings": {"name": "amount"}},
        {"capability_id": "pandas.DataFrame.to_json", "bindings": {"path": "reports/live/grouped_json_report.json"}}
      ]
    },
    {
      "task_id": "csv_json_hard_negative",
      "track": "hard_negative",
      "prompt": "Load the supplied CSV as a table; reject readers for other input formats.",
      "input_artifact_type": "file/csv",
