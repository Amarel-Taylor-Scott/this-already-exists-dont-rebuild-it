{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/package-release.schema.json",
  "title": "Observed Python package release",
  "type": "object",
  "required": ["package_id", "ecosystem", "name", "normalized_name", "version", "source_digest", "evidence_level"],
  "properties": {
    "package_id": {"type": "string", "minLength": 1},
    "ecosystem": {"const": "pypi"},
    "name": {"type": "string", "minLength": 1},
    "normalized_name": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "version": {"type": "string", "minLength": 1},
    "summary": {"type": "string"},
    "requires_python": {"type": ["string", "null"]},
    "license_expression": {"type": ["string", "null"]},
    "requirements": {"type": "array", "items": {"type": "string"}},
    "source_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "evidence_level": {"enum": ["metadata_only", "static_source", "smoke_tested", "contract_tested", "accepted_route"]}
  },
  "additionalProperties": true
}

