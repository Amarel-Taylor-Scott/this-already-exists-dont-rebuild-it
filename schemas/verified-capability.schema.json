{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/verified-capability.schema.json",
  "title": "Contract-tested package operation",
  "type": "object",
  "required": ["capability_id", "package_name", "package_version", "qualified_name", "inputs", "outputs", "executor_id", "evidence_level"],
  "properties": {
    "capability_id": {"type": "string", "minLength": 1},
    "package_name": {"type": "string", "minLength": 1},
    "package_version": {"type": "string", "minLength": 1},
    "qualified_name": {"type": "string", "minLength": 1},
    "purpose": {"type": "string", "minLength": 1},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "inputs": {"$ref": "#/$defs/ports"},
    "outputs": {"$ref": "#/$defs/ports"},
    "executor_id": {"type": "string", "minLength": 1},
    "evidence_level": {"enum": ["contract_tested", "accepted_route"]}
  },
  "$defs": {
    "ports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "artifact_type"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "artifact_type": {"type": "string", "minLength": 1},
          "required": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}

